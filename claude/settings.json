{
  "cleanupPeriodDays": 365,
  "env": {
    "DISABLE_AUTOCOMPACT": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "WebFetch",
      "WebSearch",
      "Skill",
      "mcp__*",
      "mcp__pi-tools-bridge__*"
    ],
    "deny": [
      "Agent",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "Monitor",
      "NotebookEdit",
      "PushNotification",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/session-info.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/scripts/hook-handle-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/junghan/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/junghan/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "telegram@claude-plugins-official": false
  },
  "language": "Korean",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "normal",
  "verbose": false,
  "preferredNotifChannel": "notifications_disabled",
  "autoCompactEnabled": false,
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false,
  "agentPushNotifEnabled": true,
  "useAutoModeDuringPlan": false,
  "autoMemoryEnabled": false,
  "voiceEnabled": true,
  "autoUpdates": true
}
